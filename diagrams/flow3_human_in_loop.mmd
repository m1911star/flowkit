flowchart TD
    start["🚀 Start\n<i>order request</i>"]
    calc["⚙️ Calculate\n<i>compute total</i>"]
    approve["👤 Human Approval\n<i>⏸ PAUSE here</i>"]
    process["⚙️ Process\n<i>finalize order</i>"]
